{
  "name": "agentlayer",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "git config --local core.hooksPath .githooks",
    "format": "oxfmt .",
    "typecheck": "turbo run typecheck --log-order=grouped",
    "test": "turbo run test --log-order=grouped"
  },
  "devDependencies": {
    "@types/bun": "1.3.9",
    "oxfmt": "0.33.0",
    "turbo": "2.8.9"
  },
  "packageManager": "bun@1.3.9"
}
